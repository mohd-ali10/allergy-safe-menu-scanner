// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId} (matches Firebase Auth UID)
// Fields:
//   - uid: string (required) - The user's unique identifier
//   - allergies: list of strings (required) - User's allergy preferences
//   - updatedAt: timestamp (optional) - Last update time
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "m.aleejee.007@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'allergies']) &&
             data.uid is string &&
             data.uid == request.auth.uid &&
             data.allergies is list &&
             data.allergies.size() <= 50; // Limit number of allergies
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User profiles
    match /users/{userId} {
      // Users can only read and write their own profile
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if isOwner(userId) || isAdmin();

      // Scans subcollection
      match /scans/{scanId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // Connection test path
    match /test/connection {
      allow read: if true;
    }
  }
}
